{
  "version": 2,
  "builds": [
    {
      "src": "Server/server.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    },
    {
      "src": "client/*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "Server/server.py"
    },
    {
      "src": "/dashboard",
      "dest": "client/dashboard.html"
    },
    {
      "src": "/(.*)",
      "dest": "client/index.html"
    }
  ]
}